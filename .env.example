TELEGRAM_TOKEN=
OPENAI_API_KEY=

# Railway PostgreSQL. Локально без переменной используется SQLite.
DATABASE_URL=
TELEGRAM_CHAT_ID=
TIMEZONE=Europe/Moscow
DIGEST_HOUR=19
DIGEST_MINUTE=0
HH_POLL_INTERVAL_SECONDS=600
SCORING_THRESHOLD=70
SHADOW_MODE=true
HH_USER_AGENT=AI Career Agent/2.0 (contact@example.com)
HH_ACCESS_TOKEN=
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# Модели можно заменить без изменения кода.
OPENAI_SCORING_MODEL=gpt-5.6-luna
OPENAI_WRITING_MODEL=gpt-5.6-terra
OPENAI_FALLBACK_MODEL=gpt-4.1-mini

# LinkedIn Job Alerts через Gmail OAuth.
GMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_LABEL=LinkedIn-Jobs

# Отдельный Telegram user-account через MTProto.
TELEGRAM_SOURCES_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Публичные Telegram-каналы без MTProto/API ID.
TELEGRAM_WEB_ENABLED=false
TELEGRAM_WEB_CHANNELS=forproducts,jobs_pm,careerstation_pm,remotegeekjob,remoteit,evacuatejobs,it_vakansii_jobs,careerspace
TELEGRAM_WEB_LOOKBACK_HOURS=72
TELEGRAM_WEB_MAX_POSTS_PER_CHANNEL=5
